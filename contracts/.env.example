# Mantle network RPCs
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Mantlescan API key for verification (get from https://mantlescan.xyz/myapikey)
MANTLESCAN_API_KEY=

# Deployer EOA — NEVER COMMIT THE REAL KEY (use forge keystore or env var)
# Example: cast wallet import sgsmm-deployer --interactive
DEPLOYER_PRIVATE_KEY=

# Mantle Sepolia contract addresses (filled after deploy)
SGSMM_VAULT_ADDRESS=
MIRROR_EXECUTOR_ADDRESS=
DECISION_LOG_ADDRESS=
AGENT_IDENTITY_NFT_ADDRESS=

# Authorized agent EOA (only this address can call MirrorExecutor)
AGENT_OPERATOR_ADDRESS=

# Pyth contract on Mantle Sepolia
PYTH_SEPOLIA_ADDRESS=0x98046Bd286715D3B0BC227Dd7a956b83D8978603
